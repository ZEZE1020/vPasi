# ============================================================
# vPasi Backend — Environment Variables
# ============================================================
# Copy the root .env.example instead:  cp ../.env.example .env
# This file kept for standalone backend development.
# ============================================================

# ── Environment ──────────────────────────────────────────────
ENVIRONMENT=dev
LOG_LEVEL=DEBUG

# ── Africa's Talking ─────────────────────────────────────────
AT_API_KEY=your_africastalking_api_key_here
AT_USERNAME=sandbox

# ── Google Cloud / Gemini ────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_PROJECT_ID=your-gcp-project-id
GOOGLE_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-2.0-flash

# ── LangGraph / LangSmith ───────────────────────────────────
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=vpasi

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL=300

# ── Postgres ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://vpasi:vpasi_dev_password@localhost:5432/vpasi

# ── Server ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
