# ============================================================
# vPasi — Environment Variables (all services)
# ============================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# NEVER commit .env to git.
# ============================================================

# ── Environment ──────────────────────────────────────────────
ENVIRONMENT=dev
LOG_LEVEL=DEBUG

# ── Africa's Talking (REQUIRED) ──────────────────────────────
# Get your key at: https://account.africastalking.com/
AT_API_KEY=your_africastalking_api_key_here
AT_USERNAME=sandbox

# ── Google / Gemini (REQUIRED) ───────────────────────────────
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_PROJECT_ID=vpasi-dev
GOOGLE_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-2.0-flash

# ── LangGraph / LangSmith (optional — for tracing) ──────────
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=vpasi

# ── Redis ────────────────────────────────────────────────────
# docker compose sets REDIS_URL automatically; override here for local dev
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL=300

# ── Postgres ─────────────────────────────────────────────────
# These are used by the postgres container AND by DATABASE_URL
POSTGRES_USER=vpasi
POSTGRES_PASSWORD=vpasi_dev_password
POSTGRES_DB=vpasi
# docker compose overrides DATABASE_URL automatically; this is for local dev
DATABASE_URL=

# ── Backend Server ───────────────────────────────────────────
HOST=0.0.0.0
PORT=8080

# ── Frontend ─────────────────────────────────────────────────
# Leave empty to use Vite proxy (recommended for dev)
VITE_API_URL=
